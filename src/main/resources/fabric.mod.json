{
  "schemaVersion": 1,
  "id": "modernmodelformat",
  "version": "${version}",
  "name": "ModernModelFormat",
  "description": "Allows loading of 1.21.11 models in newer versions",
  "authors": [
    "Nico_44"
  ],
  "contact": {
    "issues": "https://github.com/Nico44YT/ModernModelFormat/issues",
    "sources": "https://github.com/Nico44YT/ModernModelFormat"
  },
  "license": "GPL-3.0",
  "icon": "assets/modernmodelformat/icon.png",
  "environment": "client",
  "accessWidener": "modernmodelformat.accesswidener",
  "entrypoints": {
    "client": [
      "nico.modernmodelformat.ModernModelFormat"
    ]
  },
  "mixins": [
    "modernmodelformat.mixins.json"
  ],
  "depends": {
    "fabricloader": "*",
    "minecraft": ">=${min_minecraft_version} <=${max_minecraft_version}"
  },
  "custom": {
    "loom:injected_interfaces": {
      "net/minecraft/class_789": [
        "nico/modernmodelformat/format/ModernRotationWrapper"
      ]
    }
  }
}
